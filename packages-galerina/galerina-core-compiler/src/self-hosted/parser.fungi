@version 1
/// @file: parser.fungi
/// @purpose: Galerina parser â€” Milestone 2: flow declaration headers + body stmts
/// @status: Stage B milestone â€” parses pure/guarded/secure/flow declarations + body stmts
/// @phase: 46
/// test_status: milestone

// ============================================================
// Galerina Self-Hosted Parser â€” Milestone 1
//
// Parses flow declaration headers from a token stream produced
// by lexer.fungi. Emits FlowDecl records for each flow found.
//
// Constructs parsed:
//   1. Module-level flow declarations (pure/guarded/secure/flow)
//   2. Parameter lists: readonly name: Type, name: Type
//   3. Return type annotation (lexer emits "-" and ">" separately)
//   4. with effects [...] clause (dotted effect names collected)
//   5. Shallow flow body (brace-balanced skip)
//
// Capabilities: while loops, mut reassignment, match, Array.empty/append,
//               list.get(pos), cross-flow calls.
// ============================================================

// â”€â”€ AST node types â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

record FlowParam {
  name: String
  typeName: String
  isReadonly: Bool
  isTainted: Bool     // C4 (bridge 0145/0147): carried, no longer silently dropped
  sourceFrom: String  // C4: `source_from Origin` suffix; "" = none
}

// â”€â”€ Expression AST (folded from body-parser.fungi, Milestone M-A) â”€â”€
// Self-referential children via Array<Self>; supported by the runtime.
record Expr {
  kind: String          // "lit" | "name" | "binary" | "unary" | "call"
  value: String         // lit: literal text; name: identifier; binary/unary: operator; call: callee name
  litType: String       // lit only: "Int" | "String" | "Bool"; otherwise ""
  children: Array<Expr> // binary: [left, right]; unary: [operand]; call: args; lit/name: empty
}

record ExprParse {
  expr: Expr
  nextPos: Int          // index just past the last token consumed by this expression
}

// A structured statement node (folded from body-parser.fungi, Milestone M-A).
// LAYOUT NOTE: the first 6 fields (kind..elseBody) are slot-stable — the JS WASM reader in
// wat-p9-parser-stmt-parity.test.mjs reads slots 0..5 by index. New fields must be appended AFTER
// elseBody to preserve those slot numbers.
record Stmt {
  kind: String         // "let" | "mut" | "assign" | "return" | "if" | "while" | "exprStmt"
  name: String         // let/mut/assign target name; otherwise ""
  typeName: String     // let/mut declared type (token after ':'); otherwise ""
  expr: Array<Expr>    // 0 or 1 element: RHS / return value / if-while condition          slot 3
  body: Array<Stmt>    // if/while block statements (if: the then-block); otherwise empty   slot 4
  elseBody: Array<Stmt> // if: the else-block statements; otherwise empty                  slot 5
  // Extended fields (slot 6+): used by type-checker body checks; emitter defaults to 0/false/empty.
  typeBase: String     // generic base name (e.g. "Array", "Result"); "" for non-generic bindings
  typeArgs: Array<String> // generic type argument list; empty for non-generic bindings
  isBranded: Bool      // true for a branded-type binding (Brand<T,"Name">); false by default
  isTensor: Bool       // true for a Tensor<Elem,[dims]> binding; false by default
  litI32Overflow: Bool // true when an Int literal exceeds the i32 range; false by default
  arms: Array<Stmt>    // match: the parsed arm statements (kept in .body too); empty otherwise
}

record StmtParse { stmt: Stmt, nextPos: Int }
record BlockParse { stmts: Array<Stmt>, nextPos: Int }

// A decomposed return expression â€” Phase S6 bridge to the self-hosted
// type-checker.fungi and gir-emitter.fungi, which both consume exactly this shape.
//   kind     : "literal" | "param" | "arith" | "compare"
//   litType  : for literal/param, the static type ("Int"/"String"/"Bool"/"Unknown")
//   leftType : for arith/compare, the type of the left operand
//   rightType: for arith/compare, the type of the right operand
// Unused fields are "" (empty string).
record ReturnExpr {
  kind: String
  litType: String
  leftType: String
  rightType: String
}

record FlowDecl {
  kind: String
  name: String
  params: Array<FlowParam>
  returnType: String
  effects: Array<String>
  conformsTo: String        // domain guard policy name from contract [conforms_to: X]; "" if not bound
  body: Array<Stmt>
  returnExpr: ReturnExpr
  classification: String    // "safety_critical" | "standard" | ""; parsed from contract annotations
  deterministic: Bool       // true when the flow declares deterministic_execution in its contract
  usedEffects: Array<String> // effects decomposed from the body by the parser; empty when not computed
}

// A domain guard policy declaration:
//   policy PolicyName { permitted_effects { effect.name, ... } }
// Collected from top-level `policy Name { ... }` declarations.
record PolicyDecl {
  name: String
  permittedEffects: Array<String>
}

// ── v2.2 AST node declarations ───────────────────────────────
// These records capture the new syntax constructs introduced in v2.2.
// They are emitted by the Stage B parser and consumed by the v2.2 checkers.

// GuardDecl — top-level domain ceiling: guard GuardName { permitted_effects {} enforced_limits {} }
// Replaces PolicyDecl for named guards; PolicyDecl retained for back-compat.
record GuardDecl {
  name: String
  permittedEffects: Array<String>
  enforcedLimits: Array<String>   // enforced_limits entries (key=value pairs encoded as "key=value" strings)
}

// AccessDecl — inline access {} block with grant clauses inside a contract.
record AccessDecl {
  flowName: String
  grantedTypes: Array<String>
}

// GateDecl — gate(condition) {} admission guard at flow entry.
record GateDecl {
  flowName: String
  condition: String
  policyRef: String
}

// StaticDecl — static NAME = EXPR compile-time constant.
record StaticDecl {
  name: String
  valueExpr: String
  inferredType: String
}

// BitfieldDecl — bitfield NAME { field: bit } governance register.
record BitfieldDecl {
  name: String
  fields: Array<String>
}

// TrapDecl — trap CONDITION : ERR_CODE (inverted ensure; fires when condition is false).
record TrapDecl {
  condition: String
  errorCode: String
  flowName: String
}

// StepExpr — step EXPR cross-boundary DWI call.
record StepExpr {
  targetExpr: String
  flowName: String
}

// EvictExpr — evict ALIAS removes a loaded plugin from the DWI isolate.
record EvictExpr {
  alias: String
  flowName: String
}

// AssimilatedPluginDecl — import plugin assimilate declaration for Hot-Code Residency.
record AssimilatedPluginDecl {
  pluginPath: String
  alias: String
}

// GovernedFlowDecl — governed flow qualifier (DAG-edge validation).
record GovernedFlowDecl {
  floorName: String
  flowName: String
  dagEdges: Array<String>
}

// PolicyMutationDecl — policy {} inside contract for permitted state transitions.
record PolicyMutationDecl {
  flowName: String
  transitions: Array<String>
}

// Result of parsing a dot-separated token path (e.g. "database.write").
record DotPathParse {
  name: String
  nextPos: Int
}

record ParseResult {
  flows: Array<FlowDecl>
  errors: Array<String>
  imports: Array<String>        // module paths from `import ... from "path"` statements
  policies: Array<PolicyDecl>   // domain guard policies (task #56)
  guardDecls: Array<GuardDecl>  // v2.2 named guard ceiling declarations (task #97/#98)
}

// â”€â”€ Dot-path helper â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Parses a dot-separated identifier path from position startPos.
// Example: at pos pointing to "database", ".", "write" â†’ returns "database.write"
// Used for effect names in effects {} and permitted_effects {} blocks.
pure flow parseDotPath(tokens: Array<Token>, startPos: Int) -> DotPathParse
contract {
  intent { "Parse a dot-separated token path (e.g. gateway.charge) from startPos." }
}
{
  let total: Int = tokens.count()
  let firstOpt = tokens.get(startPos)
  match firstOpt {
    None => { return { name: "", nextPos: startPos + 1 } }
    Some(first) => {
      mut name: String = first.value
      mut p: Int = startPos + 1
      while p < total and tokVal(tokens, p) == "." {
        p = p + 1
        let sfOpt = tokens.get(p)
        match sfOpt {
          Some(sfTok) => { name = name + "." + sfTok.value  p = p + 1 }
          None => {}
          _ => {}
        }
      }
      return { name: name, nextPos: p }
    }
    _ => { return { name: "", nextPos: startPos + 1 } }
  }
}

// â”€â”€ Token accessor helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

pure flow tokVal(tokens: Array<Token>, pos: Int) -> String
contract { intent { "Safely read token value at pos; empty string when out of bounds." } }
{
  let opt = tokens.get(pos)
  match opt {
    None => { return "" }
    Some(tok) => { return tok.value }
    _ => { return "" }
  }
}

// True when the token at pos is a Keyword token with the given value.
// (folded from body-parser.fungi; the old no-arg isKw was unused and removed.)
pure flow isKw(tokens: Array<Token>, pos: Int, kw: String) -> Bool
contract { intent { "True when the token at pos is a Keyword token with the given value." } }
{
  let opt = tokens.get(pos)
  match opt {
    None => { return false }
    Some(tok) => {
      match tok.kind {
        Keyword => { return tok.value == kw }
        _ => { return false }
      }
    }
    _ => { return false }
  }
}

// True when the token at pos is an Identifier token.
pure flow isIdent(tokens: Array<Token>, pos: Int) -> Bool
contract { intent { "True when the token at pos is an Identifier token." } }
{
  let opt = tokens.get(pos)
  match opt {
    None => { return false }
    Some(tok) => {
      match tok.kind {
        Identifier => { return true }
        _ => { return false }
      }
    }
    _ => { return false }
  }
}

// True when the token at pos is an Operator/Symbol token with the given value.
pure flow isOpSym(tokens: Array<Token>, pos: Int, val: String) -> Bool
contract { intent { "True when the token at pos is an Operator/Symbol token with the given value." } }
{
  let opt = tokens.get(pos)
  match opt {
    None => { return false }
    Some(tok) => {
      match tok.kind {
        Operator => { return tok.value == val }
        Symbol   => { return tok.value == val }
        _        => { return false }
      }
    }
    _ => { return false }
  }
}

// True when the token at pos is a Newline token.
pure flow isNewline(tokens: Array<Token>, pos: Int) -> Bool
contract { intent { "True when the token at pos is a Newline token." } }
{
  let opt = tokens.get(pos)
  match opt {
    None => { return false }
    Some(tok) => {
      match tok.kind {
        Newline => { return true }
        _ => { return false }
      }
    }
    _ => { return false }
  }
}

// â”€â”€ Return-expression decomposition (Phase S6) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

// Classify a single operand token at `pos` into a static type name.
//   NumberLiteral â†’ "Int"
//   StringLiteral â†’ "String"
//   true/false    â†’ "Bool"  (Keyword tokens whose value is the literal)
//   anything else â†’ "Unknown"  (identifier / param reference)
// Reads the token's TokenKind enum (match), mirroring isKw's pattern.
pure flow classifyOperandType(tokens: Array<Token>, pos: Int) -> String
contract { intent { "Map a return-operand token to its static type for arith/compare decomposition." } }
{
  let opt = tokens.get(pos)
  match opt {
    None => { return "Unknown" }
    Some(tok) => {
      match tok.kind {
        NumberLiteral => { return "Int" }
        StringLiteral => { return "String" }
        Keyword => {
          if tok.value == "true" { return "Bool" }
          if tok.value == "false" { return "Bool" }
          return "Unknown"
        }
        _ => { return "Unknown" }
      }
    }
    _ => { return "Unknown" }
  }
}

// True when the operator value names a comparison operator (compare),
// false when it names an arithmetic operator (arith).
pure flow isCompareOp(op: String) -> Bool
contract { intent { "Distinguish compare operators from arithmetic operators by value." } }
{
  if op == "==" { return true }
  if op == "!=" { return true }
  if op == "<"  { return true }
  if op == ">"  { return true }
  if op == "<=" { return true }
  if op == ">=" { return true }
  return false
}

// True when the operator value names an arithmetic operator.
pure flow isArithOp(op: String) -> Bool
contract { intent { "True when op is one of + - * / (arithmetic)." } }
{
  if op == "+" { return true }
  if op == "-" { return true }
  if op == "*" { return true }
  if op == "/" { return true }
  return false
}

// Decompose the return expression beginning at `startPos` (the first token
// AFTER the `return` keyword) into a ReturnExpr record. Reads at most three
// tokens: operand, optional operator, optional right operand.
//   single literal       â†’ { kind: "literal", litType: <type>, "", "" }
//   single identifier    â†’ { kind: "param",   litType: "Unknown", "", "" }
//   X (+ - * /) Y        â†’ { kind: "arith",   litType: "", leftType, rightType }
//   X (== != < > <= >=) Yâ†’ { kind: "compare", litType: "", leftType, rightType }
pure flow decomposeReturn(tokens: Array<Token>, startPos: Int) -> ReturnExpr
contract { intent { "Decompose a flow's return-expression tokens into the checker/emitter ReturnExpr shape." } }
{
  let opVal: String = tokVal(tokens, startPos + 1)
  let binary: Bool = isArithOp(opVal) or isCompareOp(opVal)

  if binary {
    let leftType: String = classifyOperandType(tokens, startPos)
    let rightType: String = classifyOperandType(tokens, startPos + 2)
    if isCompareOp(opVal) {
      return { kind: "compare", litType: "", leftType: leftType, rightType: rightType }
    }
    return { kind: "arith", litType: "", leftType: leftType, rightType: rightType }
  }

  // Single-operand return: literal or name reference.
  let opt = tokens.get(startPos)
  match opt {
    None => { return { kind: "literal", litType: "Unknown", leftType: "", rightType: "" } }
    Some(tok) => {
      match tok.kind {
        NumberLiteral => { return { kind: "literal", litType: "Int", leftType: "", rightType: "" } }
        StringLiteral => { return { kind: "literal", litType: "String", leftType: "", rightType: "" } }
        Keyword => {
          if tok.value == "true" { return { kind: "literal", litType: "Bool", leftType: "", rightType: "" } }
          if tok.value == "false" { return { kind: "literal", litType: "Bool", leftType: "", rightType: "" } }
          return { kind: "param", litType: "Unknown", leftType: "", rightType: "" }
        }
        Identifier => { return { kind: "param", litType: "Unknown", leftType: "", rightType: "" } }
        _ => { return { kind: "literal", litType: "Unknown", leftType: "", rightType: "" } }
      }
    }
    _ => { return { kind: "literal", litType: "Unknown", leftType: "", rightType: "" } }
  }
}

// â”€â”€ Sub-parsers (called by parseFlows) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

// P9 brick 1 (self-hosted generics): read a base type name plus an OPTIONAL balanced generic argument
// list, concatenated into one flat string with no spaces — byte-identical to the TS parser's parseTypeRef
// (parser.ts). So `x: Array<Token>` yields the typeName "Array<Token>" instead of the base-only "Array"
// (which erased the element type and produced Array<Auto> downstream → the #100 unreachable trap). For a
// NON-generic type this reduces to the base token and pos+1, so non-generic params parse byte-identically.
pure flow readTypeName(tokens: Array<Token>, pos: Int) -> String
contract { intent { "Read a base type name plus an optional balanced generic argument list into a flat string (matches TS parseTypeRef)." } }
{
  mut name: String = tokVal(tokens, pos)
  mut p: Int = pos + 1
  mut depth: Int = 0
  mut scanning: Bool = tokVal(tokens, p) == "<"
  while scanning {
    let t: String = tokVal(tokens, p)
    if t == "" { scanning = false }
    if t == "<" { name = name + "<"  depth = depth + 1  p = p + 1 }
    if t == ">" { name = name + ">"  depth = depth - 1  p = p + 1  if depth == 0 { scanning = false } }
    if t != "" and t != "<" and t != ">" { name = name + t  p = p + 1 }
  }
  return name
}

// P9 brick 1: the token position just past a (possibly generic) type that starts at pos — the base name
// plus any balanced < ... > argument list. Mirrors readTypeName's scan so the two never disagree on where a
// type ends. For a non-generic type this is pos + 1 (identical to the old fixed advance).
pure flow typeEndPos(tokens: Array<Token>, pos: Int) -> Int
contract { intent { "Return the token position just past a (possibly generic) type starting at pos." } }
{
  mut p: Int = pos + 1
  mut depth: Int = 0
  mut scanning: Bool = tokVal(tokens, p) == "<"
  while scanning {
    let t: String = tokVal(tokens, p)
    if t == "" { scanning = false }
    if t == "<" { depth = depth + 1  p = p + 1 }
    if t == ">" { depth = depth - 1  p = p + 1  if depth == 0 { scanning = false } }
    if t != "" and t != "<" and t != ">" { p = p + 1 }
  }
  return p
}

// Parse "(" paramName: TypeName, ... ")" starting at pos.
// Returns [params, newPos] encoded as a record { params, pos }.
pure flow parseParams(tokens: Array<Token>, startPos: Int) -> Array<FlowParam>
contract { intent { "Parse a parenthesised parameter list. Caller must advance past '('." } }
{
  mut p: Int = startPos
  mut params: Array<FlowParam> = Array.empty()
  mut scanning: Bool = true
  while scanning {
    let pv = tokVal(tokens, p)
    if pv == ")" { scanning = false }
    if pv == "" { scanning = false }
    if pv == "," { p = p + 1 }
    let isBoundary: Bool = pv == ")" or pv == "" or pv == ","
    if isBoundary == false {
      // C4 (bridge 0147): qualifier LOOP accumulating readonly/tainted in ANY order — mirrors the
      // TS parseParam for(;;) (parser.ts:1085-1089). The old shape (a readonly-only special case
      // plus a generic branch hardcoding isReadonly: false) silently DISCARDED `readonly` whenever
      // another qualifier followed it: the special branch misread the next qualifier as the param
      // name, bailed without appending, and the param was later re-captured by the generic branch
      // with isReadonly: false — a silent loss of an immutability guarantee (probe rows 3-5).
      mut isRo: Bool = false
      mut isTa: Bool = false
      mut quals: Bool = true
      while quals {
        let qv = tokVal(tokens, p)
        if qv == "readonly" { isRo = true  p = p + 1 }
        if qv == "tainted" { isTa = true  p = p + 1 }
        let isQual: Bool = qv == "readonly" or qv == "tainted"
        if isQual == false { quals = false }
      }
      // ONE capture path — the ONLY place a FlowParam is constructed. A second capture site with a
      // hardcoded flag literal is exactly what let a safety property be silently asserted false.
      let pname = tokVal(tokens, p)
      let colon = tokVal(tokens, p + 1)
      let ptype = readTypeName(tokens, p + 2)
      if colon == ":" {
        mut endP: Int = typeEndPos(tokens, p + 2)
        // Optional `source_from Origin` suffix after the type (TS parser.ts:1116-1131). Origin may
        // be dotted (Network.ClientSocket): accumulate tokens up to the parameter boundary,
        // matching the TS identifier/dot run within a param list.
        mut srcFrom: String = ""
        if tokVal(tokens, endP) == "source_from" {
          endP = endP + 1
          mut srcScan: Bool = true
          while srcScan {
            let sv = tokVal(tokens, endP)
            let srcEnd: Bool = sv == "" or sv == "," or sv == ")"
            if srcEnd { srcScan = false }
            if srcEnd == false { srcFrom = srcFrom + sv  endP = endP + 1 }
          }
        }
        params = params.append({ name: pname, typeName: ptype, isReadonly: isRo, isTainted: isTa, sourceFrom: srcFrom })
        p = endP
      }
      if colon != ":" { p = p + 1 }
    }
  }
  return params
}

// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
// BODY PARSER â€” full statement + expression AST (Milestone M-A)
// Folded from body-parser.fungi. parseBlock yields a nested Stmt/Expr AST.
//
// Expression cascade (LOW -> HIGH, each left-associative):
//   parseExpr -> parseComparison (== != < > <= >=) -> parseAdditive (+ -)
//             -> parseMultiplicative (* /) -> parsePrimary (lit/name/call/group)
// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

// Token value at pos; "" when out of bounds.
pure flow eTokVal(tokens: Array<Token>, pos: Int) -> String
contract { intent { "Read token value at pos; empty string when out of bounds." } }
{
  let opt = tokens.get(pos)
  match opt {
    None => { return "" }
    Some(tok) => { return tok.value }
    _ => { return "" }
  }
}

// Skip leading Newline tokens; return the first non-Newline index >= pos.
pure flow skipNewlines(tokens: Array<Token>, pos: Int) -> Int
contract { intent { "Advance past Newline tokens; an expression does not span a newline." } }
{
  mut p: Int = pos
  let total: Int = tokens.count()
  mut scanning: Bool = true
  while p < total and scanning {
    let opt = tokens.get(p)
    match opt {
      None => { scanning = false }
      Some(tok) => {
        match tok.kind {
          Newline => { p = p + 1 }
          _ => { scanning = false }
        }
      }
      _ => { scanning = false }
    }
  }
  return p
}

// True when the operator value names a comparison operator at this level.
pure flow isCmpOp(op: String) -> Bool
contract { intent { "Comparison operators: == != < > <= >=." } }
{
  if op == "==" { return true }
  if op == "!=" { return true }
  if op == "<"  { return true }
  if op == ">"  { return true }
  if op == "<=" { return true }
  if op == ">=" { return true }
  return false
}

// Parse an atom: literal, identifier (name or call), or parenthesised group.
pure flow parsePrimary(tokens: Array<Token>, pos: Int) -> ExprParse
contract { intent { "Parse a primary expression: literal, name, call, or ( group )." } }
{
  let p: Int = skipNewlines(tokens, pos)
  let opt = tokens.get(p)
  match opt {
    None => {
      return { expr: { kind: "name", value: "", litType: "", children: Array.empty() }, nextPos: p }
    }
    Some(tok) => {
      match tok.kind {
        NumberLiteral => {
          return { expr: { kind: "lit", value: tok.value, litType: "Int", children: Array.empty() }, nextPos: p + 1 }
        }
        StringLiteral => {
          return { expr: { kind: "lit", value: tok.value, litType: "String", children: Array.empty() }, nextPos: p + 1 }
        }
        Keyword => {
          if tok.value == "true" {
            return { expr: { kind: "lit", value: "true", litType: "Bool", children: Array.empty() }, nextPos: p + 1 }
          }
          if tok.value == "false" {
            return { expr: { kind: "lit", value: "false", litType: "Bool", children: Array.empty() }, nextPos: p + 1 }
          }
          return { expr: { kind: "name", value: tok.value, litType: "", children: Array.empty() }, nextPos: p + 1 }
        }
        Identifier => {
          if eTokVal(tokens, p + 1) == "(" {
            return parseCallArgs(tokens, p + 1, tok.value)
          }
          // Member access / method call: identifier.field or identifier.method(args)
          // Handle by returning the name here, then the parseUnary caller chains dots
          // via parseMemberChain (see below).
          return { expr: { kind: "name", value: tok.value, litType: "", children: Array.empty() }, nextPos: p + 1 }
        }
        Symbol => {
          if tok.value == "(" {
            let inner: ExprParse = parseExpr(tokens, p + 1)
            let afterPos: Int = skipNewlines(tokens, inner.nextPos)
            if eTokVal(tokens, afterPos) == ")" {
              return { expr: inner.expr, nextPos: afterPos + 1 }
            }
            return { expr: inner.expr, nextPos: afterPos }
          }
          // Array literal: [ e1, e2, ... ]
          if tok.value == "[" {
            return parseArrayLiteral(tokens, p + 1)
          }
          // Record literal: { field: expr, field: expr, ... }
          // Detected by peeking ahead: { <ident> ":" ... } â€” two-token lookahead.
          if tok.value == "{" {
            let peek1: String = eTokVal(tokens, p + 1)
            let peek2: String = eTokVal(tokens, p + 2)
            // Heuristic: if next two tokens are <ident> ":" it's a record literal
            let isIdent1: Bool = isIdent(tokens, p + 1)
            if isIdent1 and peek2 == ":" {
              return parseRecordLiteral(tokens, p + 1)
            }
          }
          // Terminator tokens are NOT primaries â€” a dangling operator (`return a +`)
          // must NOT consume the closing "}"/")"/"," (doing so swallowed a following
          // flow). Return an empty node WITHOUT advancing so the caller stops here.
          if tok.value == "}" or tok.value == ")" or tok.value == "," or tok.value == "]" {
            return { expr: { kind: "name", value: "", litType: "", children: Array.empty() }, nextPos: p }
          }
          return { expr: { kind: "name", value: tok.value, litType: "", children: Array.empty() }, nextPos: p + 1 }
        }
        _ => {
          return { expr: { kind: "name", value: tok.value, litType: "", children: Array.empty() }, nextPos: p + 1 }
        }
      }
    }
    _ => {
      return { expr: { kind: "name", value: "", litType: "", children: Array.empty() }, nextPos: p }
    }
  }
}

// Parse an array literal from the first element position (just past the opening "[").
// Returns an Expr{ kind:"array", children:[element exprs] }.
pure flow parseArrayLiteral(tokens: Array<Token>, startPos: Int) -> ExprParse
contract { intent { "Parse a [...] array literal; startPos is just past the opening '['." } }
{
  let total: Int = tokens.count()
  mut elements: Array<Expr> = Array.empty()
  mut p: Int = startPos
  mut scanning: Bool = true

  let firstVal: String = eTokVal(tokens, skipNewlines(tokens, p))
  if firstVal == "]" {
    p = skipNewlines(tokens, p) + 1
    scanning = false
  }

  while scanning and p < total {
    let elemParse: ExprParse = parseExpr(tokens, p)
    elements = elements.append(elemParse.expr)
    let afterElem: Int = skipNewlines(tokens, elemParse.nextPos)
    let sep: String = eTokVal(tokens, afterElem)
    if sep == "," {
      p = afterElem + 1
    }
    if sep == "]" {
      p = afterElem + 1
      scanning = false
    }
    let isSep: Bool = sep == "," or sep == "]"
    if isSep == false {
      p = afterElem
      scanning = false
    }
  }

  return { expr: { kind: "array", value: "", litType: "Array", children: elements }, nextPos: p }
}

// Parse a record literal { field: expr, field: expr }.
// `startPos` points at the first field identifier (just past the opening "{").
// Returns Expr{ kind:"record-lit", children:[nameExpr,valExpr, nameExpr,valExpr,...] }.
pure flow parseRecordLiteral(tokens: Array<Token>, startPos: Int) -> ExprParse
contract { intent { "Parse { key: expr, ... } record literal from the first field position." } }
{
  let total: Int = tokens.count()
  mut children: Array<Expr> = Array.empty()
  mut p: Int = startPos
  mut scanning: Bool = true
  while scanning and p < total {
    p = skipNewlines(tokens, p)
    if eTokVal(tokens, p) == "}" {
      p = p + 1
      scanning = false
    }
    else {
      if eTokVal(tokens, p) == "" { scanning = false }
      else {
        let fieldName: String = eTokVal(tokens, p)
        p = p + 1
        if eTokVal(tokens, p) == ":" { p = p + 1 }
        let valParse: ExprParse = parseExpr(tokens, p)
        // Field names stored as String literals so evalGIRExpr decodes them as rtStr
        children = children.append({ kind: "lit", value: fieldName, litType: "String", children: Array.empty() })
        children = children.append(valParse.expr)
        p = skipNewlines(tokens, valParse.nextPos)
        if eTokVal(tokens, p) == "," { p = p + 1 }
      }
    }
  }
  return { expr: { kind: "record-lit", value: "", litType: "Record", children: children }, nextPos: p }
}

// Wrap parsePrimary with member-access chaining: `p.x` / `p.x.y` / `xs.count()`.
// After each primary, if the very next (non-newline) token is "." followed by an
// identifier, fold it into a `member` Expr{ kind:"member", value:<field>, children:[receiver] }.
// If that identifier is immediately followed by "(" it is a method call â€” build a
// `call` Expr using the receiver+field as qualified callee.
pure flow parsePrimaryWithMember(tokens: Array<Token>, pos: Int) -> ExprParse
contract { intent { "Parse a primary then chain any .field / .method() accesses." } }
{
  let total: Int = tokens.count()
  let base: ExprParse = parsePrimary(tokens, pos)
  mut cur: Expr = base.expr
  mut p: Int = base.nextPos
  mut scanning: Bool = true

  while scanning and p < total {
    let dotPos: Int = skipNewlines(tokens, p)
    if eTokVal(tokens, dotPos) == "." {
      let fieldPos: Int = dotPos + 1
      let optField = tokens.get(fieldPos)
      match optField {
        None => { scanning = false }
        Some(fieldTok) => {
          let fname: String = fieldTok.value
          let afterField: Int = fieldPos + 1
          // Method call: receiver.method(args)
          if eTokVal(tokens, afterField) == "(" {
            let qualCallee: String = cur.value + "." + fname
            mut methodArgs: Array<Expr> = Array.empty()
            methodArgs = methodArgs.append(cur)
            // Parse arguments from afterField+1 (past "(")
            let argStart: Int = afterField + 1
            let firstA: String = eTokVal(tokens, skipNewlines(tokens, argStart))
            mut ap: Int = argStart
            if firstA == ")" {
              ap = skipNewlines(tokens, argStart) + 1
            }
            else {
              mut argScanning: Bool = true
              while argScanning and ap < total {
                let argParse: ExprParse = parseExpr(tokens, ap)
                methodArgs = methodArgs.append(argParse.expr)
                let afterArg: Int = skipNewlines(tokens, argParse.nextPos)
                let s: String = eTokVal(tokens, afterArg)
                if s == "," { ap = afterArg + 1 }
                if s == ")" { ap = afterArg + 1  argScanning = false }
                let isSep2: Bool = s == "," or s == ")"
                if isSep2 == false { ap = afterArg  argScanning = false }
              }
            }
            cur = { kind: "call", value: fname, litType: "", children: methodArgs }
            p = ap
          }
          else {
            // Field access: receiver.field â†’ kind:"member"
            mut kids: Array<Expr> = Array.empty()
            kids = kids.append(cur)
            cur = { kind: "member", value: fname, litType: "", children: kids }
            p = afterField
          }
        }
        _ => { scanning = false }
      }
    }
    else {
      scanning = false
    }
  }

  return { expr: cur, nextPos: p }
}

// Parse comma-separated argument expressions of a call. `lparenPos` points at the
// "(" Symbol; `callee` is the identifier name preceding it.
pure flow parseCallArgs(tokens: Array<Token>, lparenPos: Int, callee: String) -> ExprParse
contract { intent { "Parse comma-separated call arguments from '(' to ')'." } }
{
  let total: Int = tokens.count()
  mut args: Array<Expr> = Array.empty()
  mut p: Int = lparenPos + 1
  mut scanning: Bool = true

  let firstTok: String = eTokVal(tokens, skipNewlines(tokens, p))
  if firstTok == ")" {
    p = skipNewlines(tokens, p) + 1
    scanning = false
  }

  while scanning and p < total {
    let argParse: ExprParse = parseExpr(tokens, p)
    args = args.append(argParse.expr)
    let afterArg: Int = skipNewlines(tokens, argParse.nextPos)
    let sep: String = eTokVal(tokens, afterArg)
    if sep == "," {
      p = afterArg + 1
    }
    if sep == ")" {
      p = afterArg + 1
      scanning = false
    }
    let isSep: Bool = sep == "," or sep == ")"
    if isSep == false {
      p = afterArg
      scanning = false
    }
  }

  return { expr: { kind: "call", value: callee, litType: "", children: args }, nextPos: p }
}

// Unary prefix operators bind tighter than * / : `!x`, `-x` (and `--x` / `!!x`
// via the recursive call). "!" lowers to value "not", "-" to value "neg".
pure flow parseUnary(tokens: Array<Token>, pos: Int) -> ExprParse
contract { intent { "Parse unary prefix operators ! and - over parsePrimary." } }
{
  let p: Int = skipNewlines(tokens, pos)
  let op: String = eTokVal(tokens, p)
  if op == "!" {
    let operand: ExprParse = parseUnary(tokens, p + 1)
    mut kids: Array<Expr> = Array.empty()
    kids = kids.append(operand.expr)
    return { expr: { kind: "unary", value: "not", litType: "", children: kids }, nextPos: operand.nextPos }
  }
  if op == "-" {
    let operand: ExprParse = parseUnary(tokens, p + 1)
    mut kids: Array<Expr> = Array.empty()
    kids = kids.append(operand.expr)
    return { expr: { kind: "unary", value: "neg", litType: "", children: kids }, nextPos: operand.nextPos }
  }
  return parsePrimaryWithMember(tokens, p)
}

pure flow parseMultiplicative(tokens: Array<Token>, pos: Int) -> ExprParse
contract { intent { "Left-associative * and / over parseUnary." } }
{
  let total: Int = tokens.count()
  let firstParse: ExprParse = parseUnary(tokens, pos)
  mut left: Expr = firstParse.expr
  mut p: Int = firstParse.nextPos
  mut scanning: Bool = true

  while scanning and p < total {
    let opPos: Int = skipNewlines(tokens, p)
    let op: String = eTokVal(tokens, opPos)
    if op == "*" or op == "/" {
      let rightParse: ExprParse = parseUnary(tokens, opPos + 1)
      let kids: Array<Expr> = makePair(left, rightParse.expr)
      left = { kind: "binary", value: op, litType: "", children: kids }
      p = rightParse.nextPos
    }
    else {
      scanning = false
    }
  }

  return { expr: left, nextPos: p }
}

pure flow parseAdditive(tokens: Array<Token>, pos: Int) -> ExprParse
contract { intent { "Left-associative + and - over parseMultiplicative." } }
{
  let total: Int = tokens.count()
  let firstParse: ExprParse = parseMultiplicative(tokens, pos)
  mut left: Expr = firstParse.expr
  mut p: Int = firstParse.nextPos
  mut scanning: Bool = true

  while scanning and p < total {
    let opPos: Int = skipNewlines(tokens, p)
    let op: String = eTokVal(tokens, opPos)
    if op == "+" or op == "-" {
      let rightParse: ExprParse = parseMultiplicative(tokens, opPos + 1)
      let kids: Array<Expr> = makePair(left, rightParse.expr)
      left = { kind: "binary", value: op, litType: "", children: kids }
      p = rightParse.nextPos
    }
    else {
      scanning = false
    }
  }

  return { expr: left, nextPos: p }
}

pure flow parseComparison(tokens: Array<Token>, pos: Int) -> ExprParse
contract { intent { "Left-associative comparison operators over parseAdditive." } }
{
  let total: Int = tokens.count()
  let firstParse: ExprParse = parseAdditive(tokens, pos)
  mut left: Expr = firstParse.expr
  mut p: Int = firstParse.nextPos
  mut scanning: Bool = true

  while scanning and p < total {
    let opPos: Int = skipNewlines(tokens, p)
    let op: String = eTokVal(tokens, opPos)
    if isCmpOp(op) {
      let rightParse: ExprParse = parseAdditive(tokens, opPos + 1)
      let kids: Array<Expr> = makePair(left, rightParse.expr)
      left = { kind: "binary", value: op, litType: "", children: kids }
      p = rightParse.nextPos
    }
    else {
      scanning = false
    }
  }

  return { expr: left, nextPos: p }
}

// Logical and/or â€” the lowest-precedence level, below comparison. `and`/`or` are
// Keyword tokens. They share ONE left-associative level (no precedence between them),
// so `a or b and c` parses as `(a or b) and c` (left-fold), matching the Stage-A
// parser's treatment of and/or at a single level.
pure flow parseLogical(tokens: Array<Token>, pos: Int) -> ExprParse
contract { intent { "Left-associative logical and/or over parseComparison." } }
{
  let total: Int = tokens.count()
  let firstParse: ExprParse = parseComparison(tokens, pos)
  mut left: Expr = firstParse.expr
  mut p: Int = firstParse.nextPos
  mut scanning: Bool = true

  while scanning and p < total {
    let opPos: Int = skipNewlines(tokens, p)
    let op: String = eTokVal(tokens, opPos)
    if op == "and" or op == "or" {
      let rightParse: ExprParse = parseComparison(tokens, opPos + 1)
      let kids: Array<Expr> = makePair(left, rightParse.expr)
      left = { kind: "binary", value: op, litType: "", children: kids }
      p = rightParse.nextPos
    }
    else {
      scanning = false
    }
  }

  return { expr: left, nextPos: p }
}

pure flow parseExpr(tokens: Array<Token>, pos: Int) -> ExprParse
contract { intent { "Parse a full expression by recursive descent from the lowest-precedence level." } }
{
  return parseLogical(tokens, pos)
}

pure flow makePair(a: Expr, b: Expr) -> Array<Expr>
contract { intent { "Build the [left, right] children array for a binary node." } }
{
  mut out: Array<Expr> = Array.empty()
  out = out.append(a)
  out = out.append(b)
  return out
}

record ForLoopResult { stmt: Stmt  nextPos: Int }
// Parse a for loop. `startPos` is just past the `for` keyword.
// Handles:
//   for item in collection { body }  â†’ while loop with index counter + .get()
//   for i in lo..hi { body }         â†’ while loop with range
// Returns a synthetic "while" Stmt so the GIR + runtime need no new construct.
pure flow parseForLoop(tokens: Array<Token>, startPos: Int) -> ForLoopResult
contract { intent { "Parse for loop (iterator or range) and lower to a while Stmt." } }
{
  let total: Int = tokens.count()
  let varName: String = eTokVal(tokens, startPos)         // binding name (item / i)
  mut p: Int = startPos + 1
  // consume "in"
  if eTokVal(tokens, p) == "in" { p = p + 1 }
  p = skipNewlines(tokens, p)

  // Detect range form: lo..hi â€” the current token is a number/name, then ".."
  let isRange: Bool = eTokVal(tokens, p + 1) == ".."
  mut whileStmt: Stmt = { kind: "exprStmt", name: "", typeName: "", expr: Array.empty(), body: Array.empty(), elseBody: Array.empty() }
  mut endPos: Int = p

  if isRange {
    // Range form: for i in lo..hi { body }
    // lo is at p, ".." at p+1, hi at p+2
    let loExpr: ExprParse = parseExpr(tokens, p)
    mut rp: Int = loExpr.nextPos
    if eTokVal(tokens, rp) == ".." { rp = rp + 1 }
    let hiExpr: ExprParse = parseExpr(tokens, rp)
    rp = skipNewlines(tokens, hiExpr.nextPos)
    if eTokVal(tokens, rp) == "{" {
      let bodyBlk: BlockParse = parseBlock(tokens, rp + 1)
      // Append `i = i + 1` to the body
      mut incExpr: Expr = { kind: "binary", value: "+", litType: "", children: Array.empty() }
      mut addKids: Array<Expr> = Array.empty()
      addKids = addKids.append({ kind: "name", value: varName, litType: "", children: Array.empty() })
      addKids = addKids.append({ kind: "lit", value: "1", litType: "Int", children: Array.empty() })
      incExpr = { kind: "binary", value: "+", litType: "", children: addKids }
      let incStmt: Stmt = { kind: "assign", name: varName, typeName: "", expr: [incExpr], body: Array.empty(), elseBody: Array.empty() }
      mut loopBody: Array<Stmt> = bodyBlk.stmts
      loopBody = loopBody.append(incStmt)
      // Condition: i < hi
      mut condKids: Array<Expr> = Array.empty()
      condKids = condKids.append({ kind: "name", value: varName, litType: "", children: Array.empty() })
      condKids = condKids.append(hiExpr.expr)
      let condExpr2: Expr = { kind: "binary", value: "<", litType: "", children: condKids }
      // Init: mut i: Int = lo (returned as a separate let stmt â€” we use assign instead)
      // The caller receives just the while stmt; the init `mut i = lo` precedes it.
      // We pack both into a synthetic "block" using the while's body field for the init
      // and elseBody for the actual while stmt. The runtime handles this via the "forblock" op.
      // Simpler: return two stmts by embedding init in the while's `name` field and having
      // the GIR emitter detect it. Instead: just return the while and expect the caller
      // (parseStmt) to prepend the init. Since parseStmt returns one Stmt, we use a
      // "block" kind that carries the init + while.
      let initStmt: Stmt = { kind: "mut", name: varName, typeName: "Int", expr: [loExpr.expr], body: Array.empty(), elseBody: Array.empty() }
      let whileBody: Stmt = { kind: "while", name: "", typeName: "", expr: [condExpr2], body: loopBody, elseBody: Array.empty() }
      mut blockBody: Array<Stmt> = Array.empty()
      blockBody = blockBody.append(initStmt)
      blockBody = blockBody.append(whileBody)
      whileStmt = { kind: "if", name: "__forrange__", typeName: "", expr: [{ kind: "lit", value: "true", litType: "Bool", children: Array.empty() }], body: blockBody, elseBody: Array.empty() }
      endPos = bodyBlk.nextPos
    }
  }
  else {
    // Iterator form: for item in collection { body }
    let collExpr: ExprParse = parseExpr(tokens, p)
    let rp2: Int = skipNewlines(tokens, collExpr.nextPos)
    if eTokVal(tokens, rp2) == "{" {
      let bodyBlk2: BlockParse = parseBlock(tokens, rp2 + 1)
      let idxName: String = "__fori_" + varName
      // Build body: let item = collection.get(__fori).unwrapOr(default_sentinel); ..body..; __fori = __fori + 1
      // Use a match Some(x)/None pattern via the existing match infrastructure
      // Build: collection.get(idxName) â†’ call "get" with kids=[collExpr, idxExpr]
      mut getKids: Array<Expr> = Array.empty()
      getKids = getKids.append(collExpr.expr)
      getKids = getKids.append({ kind: "name", value: idxName, litType: "", children: Array.empty() })
      let getCallExpr: Expr = { kind: "call", value: "get", litType: "", children: getKids }
      // unwrapOr(getResult, default) â€” kids=[getCallExpr, defaultExpr]
      mut unwrapKids: Array<Expr> = Array.empty()
      unwrapKids = unwrapKids.append(getCallExpr)
      unwrapKids = unwrapKids.append({ kind: "lit", value: "0", litType: "Int", children: Array.empty() })
      let unwrapCall: Expr = { kind: "call", value: "unwrapOr", litType: "", children: unwrapKids }
      let itemStmt: Stmt = { kind: "let", name: varName, typeName: "", expr: [unwrapCall], body: Array.empty(), elseBody: Array.empty() }
      // Increment: idxName = idxName + 1
      mut incKids2: Array<Expr> = Array.empty()
      incKids2 = incKids2.append({ kind: "name", value: idxName, litType: "", children: Array.empty() })
      incKids2 = incKids2.append({ kind: "lit", value: "1", litType: "Int", children: Array.empty() })
      let incStmt2: Stmt = { kind: "assign", name: idxName, typeName: "", expr: [{ kind: "binary", value: "+", litType: "", children: incKids2 }], body: Array.empty(), elseBody: Array.empty() }
      mut loopBody2: Array<Stmt> = Array.empty()
      loopBody2 = loopBody2.append(itemStmt)
      mut bi2: Int = 0
      while bi2 < bodyBlk2.stmts.count() {
        let bsOpt = bodyBlk2.stmts.get(bi2)
        match bsOpt {
          Some(bs) => { loopBody2 = loopBody2.append(bs) }
          None => {}
          _ => {}
        }
        bi2 = bi2 + 1
      }
      loopBody2 = loopBody2.append(incStmt2)
      // Condition: idxName < collection.count() â†’ call "count" with kids=[collExpr]
      mut cntKids: Array<Expr> = Array.empty()
      cntKids = cntKids.append(collExpr.expr)
      let cntCall: Expr = { kind: "call", value: "count", litType: "", children: cntKids }
      mut condKids2: Array<Expr> = Array.empty()
      condKids2 = condKids2.append({ kind: "name", value: idxName, litType: "", children: Array.empty() })
      condKids2 = condKids2.append(cntCall)
      let condExpr3: Expr = { kind: "binary", value: "<", litType: "", children: condKids2 }
      // Init: mut __fori_item = 0
      let initStmt2: Stmt = { kind: "mut", name: idxName, typeName: "Int", expr: [{ kind: "lit", value: "0", litType: "Int", children: Array.empty() }], body: Array.empty(), elseBody: Array.empty() }
      let whileBody2: Stmt = { kind: "while", name: "", typeName: "", expr: [condExpr3], body: loopBody2, elseBody: Array.empty() }
      mut blockBody2: Array<Stmt> = Array.empty()
      blockBody2 = blockBody2.append(initStmt2)
      blockBody2 = blockBody2.append(whileBody2)
      whileStmt = { kind: "if", name: "__forblock__", typeName: "", expr: [{ kind: "lit", value: "true", litType: "Bool", children: Array.empty() }], body: blockBody2, elseBody: Array.empty() }
      endPos = bodyBlk2.nextPos
    }
  }
  return { stmt: whileStmt, nextPos: endPos }
}

record MatchArmsResult { arms: Array<Stmt>  nextPos: Int }

// Parse match arms from the position of the "{" that opens the match block.
// Isolated as a separate flow to give it a clean scope for `p` mutation.
// Returns MatchArmsResult{arms, nextPos} where nextPos is past the closing "}"
// (or at the current pos if no "{" was found).
pure flow parseMatchArms(tokens: Array<Token>, openBracePos: Int) -> MatchArmsResult
contract { intent { "Parse match arms { pat => { body } ... } from the opening brace." } }
{
  let total: Int = tokens.count()
  mut arms: Array<Stmt> = Array.empty()
  mut endPos: Int = openBracePos
  if eTokVal(tokens, openBracePos) == "{" {
    mut p: Int = openBracePos + 1
    mut scanning: Bool = true
    while scanning and p < total {
      p = skipNewlines(tokens, p)
      if eTokVal(tokens, p) == "}" {
        p = p + 1
        scanning = false
      }
      else {
        if eTokVal(tokens, p) == "" {
          scanning = false
        }
        else {
          let mpat: String = eTokVal(tokens, p)
          p = p + 1
          p = skipNewlines(tokens, p)
          // Constructor pattern: Some(x), Ok(v), Err(e) â€” read optional binding name
          // stored in typeName so the matche runtime handler can bind it in the arm env.
          mut bindingName: String = ""
          if eTokVal(tokens, p) == "(" {
            p = p + 1   // past "("
            let bname: String = eTokVal(tokens, p)
            if bname != ")" and bname != "" {
              bindingName = bname
              p = p + 1  // past binding name
            }
            if eTokVal(tokens, p) == ")" { p = p + 1 }  // past ")"
          }
          p = skipNewlines(tokens, p)
          if eTokVal(tokens, p) == "=>" { p = p + 1 }
          p = skipNewlines(tokens, p)
          if eTokVal(tokens, p) == "{" {
            let armBlk: BlockParse = parseBlock(tokens, p + 1)
            p = armBlk.nextPos
            mut patExpr: Expr = { kind: "lit", value: "true", litType: "Bool", children: Array.empty() }
            if mpat != "_" {
              patExpr = { kind: "lit", value: mpat, litType: "Int", children: Array.empty() }
            }
            // typeName carries the optional binding name for constructor patterns
            let armStmt: Stmt = { kind: "if", name: mpat, typeName: bindingName, expr: [patExpr], body: armBlk.stmts, elseBody: Array.empty() }
            arms = arms.append(armStmt)
          }
          else {
            p = p + 1
          }
        }
      }
    }
    endPos = p
  }
  return { arms: arms, nextPos: endPos }
}

// Parse a single statement beginning at `pos`. EVERY expression position is
// routed through the real parseExpr and the cursor is advanced to its nextPos.
pure flow parseStmt(tokens: Array<Token>, pos: Int) -> StmtParse
contract { intent { "Parse one statement; dispatch on the leading token kind/value." } }
{
  let kwLet: Bool = isKw(tokens, pos, "let")
  let kwMut: Bool = isKw(tokens, pos, "mut")
  if kwLet or kwMut {
    mut kind: String = "let"
    if kwMut { kind = "mut" }
    let name: String = tokVal(tokens, pos + 1)

    mut typeName: String = ""
    mut p: Int = pos + 2
    if isOpSym(tokens, p, ":") {
      typeName = tokVal(tokens, p + 1)
      p = p + 2
      // Skip a generic type parameter < T > so `Array<Int>` doesn't leave `<` `Int` `>` tokens
      // floating and confusing the `=` lookahead. This is a simple single-level skip.
      if eTokVal(tokens, p) == "<" {
        p = p + 1                        // advance past `<`; p is a mut in the outer scope
        mut genericDepth: Int = 1

        while genericDepth > 0 and p < tokens.count() {
          let tokenValue: String = eTokVal(tokens, p)

          if tokenValue == "<" {
            genericDepth = genericDepth + 1
          }
          if tokenValue == ">" {
            genericDepth = genericDepth - 1
          }
          if tokenValue == ">>" {
            // Nested generics like Map<K,V>> close two levels at once
            genericDepth = genericDepth - 2
          }
          if tokenValue == ">=" {
            // The lexer fuses `>` + `=` into a single `>=` token when a generic type
            // is immediately followed by `=`, e.g. `Array<Int>=value`.
            // Treat as closing `>` â€” back up after the loop so the `=` is re-read.
            genericDepth = genericDepth - 1
          }

          p = p + 1
        }

        // genericDepth > 0 means an unclosed generic â€” source is malformed.
        // Continue silently; downstream parseExpr will surface the error.

        // Restore position if the closing token was `>=` (fused `> =`) so the
        // assignment `=` is seen by the next check outside this block.
        if eTokVal(tokens, p - 1) == ">=" { p = p - 1 }
      }
    }

    // The `=` assignment may be fused with the preceding `>` as `>=` when the type
    // annotation ends a generic: `Array<Int>=value`. In that case, consume the `>=`
    // token and let parseExpr handle the RHS.
    if isOpSym(tokens, p, "=") {
      p = p + 1
    }
    if eTokVal(tokens, p) == ">=" {
      p = p + 1   // consume the fused `>=` token; `>` was the generic close, `=` is here
    }
    let rhs: ExprParse = parseExpr(tokens, p)
    let stmt: Stmt = {
      kind: kind,
      name: name,
      typeName: typeName,
      expr: [rhs.expr],
      body: Array.empty(),
      elseBody: Array.empty()
    }
    return { stmt: stmt, nextPos: rhs.nextPos }
  }

  if isKw(tokens, pos, "return") {
    let after: Int = pos + 1
    let endsStmt: Bool = isNewline(tokens, after) or isOpSym(tokens, after, "}") or tokVal(tokens, after) == ""
    if endsStmt {
      let stmt: Stmt = { kind: "return", name: "", typeName: "", expr: Array.empty(), body: Array.empty(), elseBody: Array.empty() }
      return { stmt: stmt, nextPos: after }
    }
    let rv: ExprParse = parseExpr(tokens, after)
    let stmt: Stmt = { kind: "return", name: "", typeName: "", expr: [rv.expr], body: Array.empty(), elseBody: Array.empty() }
    return { stmt: stmt, nextPos: rv.nextPos }
  }

  if isKw(tokens, pos, "if") {
    let cond: ExprParse = parseExpr(tokens, pos + 1)
    mut p: Int = cond.nextPos
    while isNewline(tokens, p) {
      p = p + 1
    }
    mut blk: BlockParse = { stmts: Array.empty(), nextPos: p }
    if isOpSym(tokens, p, "{") {
      blk = parseBlock(tokens, p + 1)
    }
    // Optional `else { ... }` â€” skip newlines, then look for the `else` keyword
    // followed by `{`. Galerina bans chained `else if`, so only `else { ... }` here.
    mut elseStmts: Array<Stmt> = Array.empty()
    mut endPos: Int = blk.nextPos
    mut q: Int = blk.nextPos
    while isNewline(tokens, q) {
      q = q + 1
    }
    if isKw(tokens, q, "else") {
      mut r: Int = q + 1
      while isNewline(tokens, r) {
        r = r + 1
      }
      if isOpSym(tokens, r, "{") {
        let elseBlk: BlockParse = parseBlock(tokens, r + 1)
        elseStmts = elseBlk.stmts
        endPos = elseBlk.nextPos
      }
    }
    let stmt: Stmt = {
      kind: "if",
      name: "",
      typeName: "",
      expr: [cond.expr],
      body: blk.stmts,
      elseBody: elseStmts
    }
    return { stmt: stmt, nextPos: endPos }
  }

  if isKw(tokens, pos, "while") {
    let cond: ExprParse = parseExpr(tokens, pos + 1)
    mut p: Int = cond.nextPos
    while isNewline(tokens, p) {
      p = p + 1
    }
    mut blk: BlockParse = { stmts: Array.empty(), nextPos: p }
    if isOpSym(tokens, p, "{") {
      blk = parseBlock(tokens, p + 1)
    }
    let stmt: Stmt = {
      kind: "while",
      name: "",
      typeName: "",
      expr: [cond.expr],
      body: blk.stmts,
      elseBody: Array.empty()
    }
    return { stmt: stmt, nextPos: blk.nextPos }
  }

  // â”€â”€ for â”€â”€
  // Two forms:
  //   for item in collection { body }  â†’ iterator-style over Array/list
  //   for i in 0..n { body }           â†’ range-style (integer range)
  // Both are lowered at parse time to `while` stmts so the GIR + runtime need no
  // new construct.
  //
  // Iterator form lowers to:
  //   mut __fi: Int = 0
  //   while __fi < collection.count() {
  //     let item = collection.get(__fi).unwrapOr(defaultVal)  -- actually we use a match
  //     __fi = __fi + 1
  //   }
  //
  // Range form `for i in lo..hi` lowers to:
  //   mut i: Int = lo
  //   while i < hi { ..body..  i = i + 1 }
  //
  // Isolated via parseForLoop to avoid the `p` scope mutation bug.
  if isKw(tokens, pos, "for") {
    let forResult: ForLoopResult = parseForLoop(tokens, pos + 1)
    return { stmt: forResult.stmt, nextPos: forResult.nextPos }
  }

  // â”€â”€ match â”€â”€
  // match <subjectExpr> { <pat> => { <body> } ... _ => { <body> } }
  // Stage B parser approach: store each arm as an individual if-stmt in the
  // Stmt.body array of a "match" kind stmt. The Stmt holds:
  //   kind="match"  expr=[subject]  body=[armStmt0, armStmt1, ...]
  // where each armStmt is kind="if", expr=[pat-as-lit or sentinel for _],
  //   body=arm-body, elseBody=[].
  // The GIR emitter + runtime handle this directly by iterating arm stmts.
  // Arm parsing is delegated to parseMatchArms (a separate flow) to avoid scope
  // issues with `p` inside deeply-nested if/while blocks in parseStmt.
  if isKw(tokens, pos, "match") {
    let subjParse: ExprParse = parseExpr(tokens, pos + 1)
    let matchBlockStart: Int = skipNewlines(tokens, subjParse.nextPos)
    let armsResult: MatchArmsResult = parseMatchArms(tokens, matchBlockStart)
    let matchStmt: Stmt = { kind: "match", name: "", typeName: "", expr: [subjParse.expr], body: armsResult.arms, elseBody: Array.empty() }
    return { stmt: matchStmt, nextPos: armsResult.nextPos }
  }

  let assignTarget: Bool = isIdent(tokens, pos) and isOpSym(tokens, pos + 1, "=")
  if assignTarget {
    let name: String = tokVal(tokens, pos)
    let rhs: ExprParse = parseExpr(tokens, pos + 2)
    let stmt: Stmt = {
      kind: "assign",
      name: name,
      typeName: "",
      expr: [rhs.expr],
      body: Array.empty(),
      elseBody: Array.empty()
    }
    return { stmt: stmt, nextPos: rhs.nextPos }
  }

  let ep: ExprParse = parseExpr(tokens, pos)
  mut next: Int = ep.nextPos
  if next <= pos {
    next = pos + 1
  }
  let stmt: Stmt = {
    kind: "exprStmt",
    name: "",
    typeName: "",
    expr: [ep.expr],
    body: Array.empty(),
    elseBody: Array.empty()
  }
  return { stmt: stmt, nextPos: next }
}

// Parse a brace-delimited block. `pos` points at the token JUST AFTER the opening
// "{". Parse statements until the matching "}", skipping Newline tokens between
// statements. nextPos is just past the closing "}".
pure flow parseBlock(tokens: Array<Token>, pos: Int) -> BlockParse
contract { intent { "Parse statements until the matching closing brace; skip newlines between statements." } }
{
  mut stmts: Array<Stmt> = Array.empty()
  mut p: Int = pos
  let total: Int = tokens.count()
  mut scanning: Bool = true

  while p < total and scanning {
    if isNewline(tokens, p) {
      p = p + 1
    }
    else {
      if isOpSym(tokens, p, "}") {
        p = p + 1
        scanning = false
      }
      else {
        if tokVal(tokens, p) == "" {
          scanning = false
        }
        else {
          let sp: StmtParse = parseStmt(tokens, p)
          stmts = stmts.append(sp.stmt)
          mut np: Int = sp.nextPos
          if np <= p {
            np = p + 1
          }
          p = np
        }
      }
    }
  }

  return { stmts: stmts, nextPos: p }
}

// Scan a brace-balanced body (from startPos, just past the opening "{") for the
// first TOP-LEVEL `return` statement and decompose its expression. Returns the
// default sentinel { kind: "literal", litType: "Unknown", "", "" } when the body
// has no top-level return. Nested sub-blocks (depth > 1) are ignored.
pure flow findReturnExpr(tokens: Array<Token>, startPos: Int, total: Int) -> ReturnExpr
contract {
  intent { "Locate the first top-level return in a body and decompose it to a ReturnExpr." }
}
{
  mut result: ReturnExpr = { kind: "literal", litType: "Unknown", leftType: "", rightType: "" }
  mut p: Int = startPos
  mut depth: Int = 1
  mut scanning: Bool = true

  while p < total and depth > 0 and scanning {
    let tv = tokVal(tokens, p)

    if tv == "}" {
      depth = depth - 1
      p = p + 1
    }
    if tv == "{" and depth > 0 {
      depth = depth + 1
      p = p + 1
    }
    let isTopReturn: Bool = tv == "return" and depth == 1
    if isTopReturn {
      result = decomposeReturn(tokens, p + 1)
      scanning = false
    }
    // Plain advance for any token not consumed by the structural handlers above.
    // "{" and "}" advance p themselves; a top-level "return" stops the scan.
    let isStructural: Bool = tv == "}" or tv == "{" or isTopReturn or tv == ""
    if isStructural == false {
      p = p + 1
    }
    if tv == "" { scanning = false }
  }

  return result
}

// â”€â”€ Main parser flow â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

// isTrivia: newline or comment token (top-level trivia the parser ignores).
// The lexer EMITS comments as tokens (Comment / DocComment / GovComment) — they are trivia at top
// level, never "unexpected tokens". Used by the FUNGI-PARSE-001 fail-closed check so error reporting
// flags only genuine garbage (R&D 0050: unconsumed NON-TRIVIA tokens).
pure flow isTrivia(tokens: Array<Token>, pos: Int) -> Bool
contract {
  intent { "True when tokens[pos] is a newline or a comment-kind token (top-level trivia)." }
}
{
  // MEASURED (probe 2026-07-23): token KIND comparisons are unreliable here — kinds surface as
  // `unresolved` values, where `kind == "Comment"` is always-false and `kind == Comment` (bare
  // member) is always-true. So trivia is decided from the token VALUE, all-proven idioms:
  //   Eof sentinel  -> value ""            comments -> value starts "//" or "/*"
  mut t: Bool = false
  if isNewline(tokens, pos) { t = true }
  let v: String = tokVal(tokens, pos)
  if v == "" { t = true }
  mut c0s: String = ""
  mut c1s: String = ""
  let c0: Option<Char> = v.charAt(0)
  match c0 {
    Some(a) => { c0s = a.toString() }
    None => {}
    _ => {}
  }
  let c1: Option<Char> = v.charAt(1)
  match c1 {
    Some(b) => { c1s = b.toString() }
    None => {}
    _ => {}
  }
  if c0s == "/" and c1s == "/" { t = true }
  if c0s == "/" and c1s == "*" { t = true }
  return t
}

pure flow parseFlows(tokens: Array<Token>) -> ParseResult
contract {
  intent { "Parse Galerina flow declarations from a token stream. Milestone 1: flow headers only. Fail-closed: malformed source reports FUNGI-PARSE-00x errors, never a silent skip (R&D 0050)." }
}
{
  mut flows: Array<FlowDecl> = Array.empty()
  mut errs: Array<String> = Array.empty()
  mut importPaths: Array<String> = Array.empty()
  mut policies: Array<PolicyDecl> = Array.empty()   // domain guard policies (task #56)
  mut guardDecls: Array<GuardDecl> = Array.empty()  // v2.2 named guard ceiling declarations
  mut pos: Int = 0
  let total: Int = tokens.count()

  while pos < total {
    let tv = tokVal(tokens, pos)
    // FUNGI-PARSE fail-closed (R&D 0050 ruling): `consumed` marks iterations where a recognized
    // branch (policy / guard / grammar-gap skip / error-recovery) already advanced `pos` — the
    // branches are SEQUENTIAL ifs (no else-chaining), so after one runs, the stale `tv` falls
    // through to the qualifier check; without this flag the unexpected-token error below would
    // false-fire on every successfully parsed policy/guard.
    mut consumed: Bool = false

    // Skip `import` statements: `import flow X from "path"` or `import { X } from "path"`
    // Record the module path in importPaths for the host to resolve and merge.
    if tv == "import" {
      mut ipos: Int = pos + 1
      // Skip until we find a string literal (the module path) or end-of-line
      mut foundPath: Bool = false
      while ipos < total and foundPath == false {
        let itv: String = tokVal(tokens, ipos)
        if itv == "" { foundPath = true }
        if isNewline(tokens, ipos) { foundPath = true }
        // The module path is the token AFTER `from` (grammar-positional, value-based). The old
        // `tok.kind == StringLiteral` bare-enum compare is ALWAYS-TRUE in the combined unit
        // (kinds surface as `unresolved`; measured 2026-07-23) — it fired on the FIRST scanned
        // token, capturing "flow" as the import path and leaving pos mid-statement (masked for
        // months by the old silent top-level skip; exposed by the FUNGI-PARSE-001 fail-closed check).
        let itok = tokens.get(ipos)
        match itok {
          Some(tok) => {
            if tokVal(tokens, ipos - 1) == "from" {
              importPaths = importPaths.append(tok.value)
              foundPath = true
            }
          }
          None => { foundPath = true }
          _ => { foundPath = true }
        }
        ipos = ipos + 1
      }
      pos = ipos
    }
    else {

    // Top-level domain guard policy declaration: policy PolicyName { permitted_effects { ... } }
    // Collected into the `policies` array; passed to governance-verifier.fungi (task #56).
    if tv == "policy" {
      mut pp: Int = pos + 1
      while isNewline(tokens, pp) { pp = pp + 1 }
      // Read the policy name
      let polNameOpt = tokens.get(pp)
      mut polName: String = ""
      match polNameOpt {
        Some(polTok) => {
          // (c) 2026-07-23 token-kind arc: VALUE-BASED / positional. The policy name is the token
          // right after `policy` (newlines already skipped). The old `polTok.kind == "Identifier"`
          // was the always-false TokenKind-vs-string compare (bridge 0086) → polName stayed "" → the
          // whole `if polName != ""` gate blocked policies.append → the decl was silently dropped
          // (0090: `policies count : 0`). A real name is any non-empty token that is not the
          // body-opening brace. Compiles identically on both backends (source, no kind check) → R3-safe.
          let pnv: String = polTok.value
          if pnv != "" and pnv != "{" { polName = pnv  pp = pp + 1 }
        }
        None => {}
        _ => {}
      }
      while isNewline(tokens, pp) { pp = pp + 1 }
      // Parse policy body { ... }
      mut permEffects: Array<String> = Array.empty()
      if tokVal(tokens, pp) == "{" {
        pp = pp + 1
        mut polDepth: Int = 1
        while pp < total and polDepth > 0 {
          let pv: String = tokVal(tokens, pp)
          if pv == "{" { polDepth = polDepth + 1 }
          if pv == "}" {
            polDepth = polDepth - 1
            if polDepth == 0 { pp = pp + 1 }
          }
          // Extract permitted_effects { e1, e2 }
          if polDepth == 1 and pv == "permitted_effects" {
            pp = pp + 1
            while isNewline(tokens, pp) { pp = pp + 1 }
            if tokVal(tokens, pp) == "{" {
              pp = pp + 1
              while pp < total and tokVal(tokens, pp) != "}" {
                let peOpt = tokens.get(pp)
                match peOpt {
                  Some(peTok) => {
                    // (c) 2026-07-23 token-kind arc: VALUE-BASED. An effect entry is any NON-newline
                    // token that is not a separator or brace; parse it as a dot-path (network.outbound).
                    // The old `match peTok.kind { Identifier | Keyword => }` was a bare-member TokenKind
                    // match (bridge 0090). The newline exclusion the old `_ =>` arm gave is kept explicit
                    // via isNewline — a multi-line permitted_effects block would otherwise capture a
                    // newline token as a spurious "\n" effect (caught by the multi-line probe before commit).
                    let pev: String = peTok.value
                    if isNewline(tokens, pp) == false and pev != "," and pev != "{" and pev != "}" {
                      let parsed = parseDotPath(tokens, pp)
                      permEffects = permEffects.append(parsed.name)
                      pp = parsed.nextPos
                      while isNewline(tokens, pp) { pp = pp + 1 }
                      if tokVal(tokens, pp) == "," { pp = pp + 1 }
                    }
                    else { pp = pp + 1 }
                  }
                  None => {}
                  _ => {}
                }
                while isNewline(tokens, pp) { pp = pp + 1 }
              }
              if tokVal(tokens, pp) == "}" { pp = pp + 1 }
            }
          } else {
            if polDepth > 0 { pp = pp + 1 }
          }
        }
      }
      if polName != "" {
        policies = policies.append({ name: polName, permittedEffects: permEffects })
      }
      pos = pp
      consumed = true
    }


    // Top-level guard declaration: guard GuardName { permitted_effects {} enforced_limits {} }
    // v2.2 — named domain ceiling; distinct from the `guarded` flow qualifier.
    if tv == "guard" {
      mut gp: Int = pos + 1
      while isNewline(tokens, gp) { gp = gp + 1 }
      let guardNameOpt = tokens.get(gp)
      mut guardName: String = ""
      match guardNameOpt {
        Some(gnTok) => {
          // (c, sibling) 2026-07-23: VALUE-BASED / positional — the guard name is the token after
          // `guard`. The old `gnTok.kind == "Identifier"` was the always-false TokenKind-vs-string
          // compare (bridge 0086/0107) → guardName stayed "" → guard declaration names silently
          // dropped. A real name is any non-empty token that is not the body-opening brace.
          let gnv: String = gnTok.value
          if gnv != "" and gnv != "{" { guardName = gnv  gp = gp + 1 }
        }
        None => {}
        _ => {}
      }
      while isNewline(tokens, gp) { gp = gp + 1 }
      mut guardPermEffects: Array<String> = Array.empty()
      mut guardLimits: Array<String> = Array.empty()
      if tokVal(tokens, gp) == "{" {
        gp = gp + 1
        mut gDepth: Int = 1
        while gp < total and gDepth > 0 {
          let gv: String = tokVal(tokens, gp)
          if gv == "{" { gDepth = gDepth + 1 }
          if gv == "}" {
            gDepth = gDepth - 1
            if gDepth == 0 { gp = gp + 1 }
          }
          if gDepth == 1 and gv == "permitted_effects" {
            gp = gp + 1
            while isNewline(tokens, gp) { gp = gp + 1 }
            if tokVal(tokens, gp) == "{" {
              gp = gp + 1
              while gp < total and tokVal(tokens, gp) != "}" {
                let geOpt = tokens.get(gp)
                match geOpt {
                  Some(geTok) => {
                    match geTok.kind {
                      Identifier | Keyword => {
                        let geParsed = parseDotPath(tokens, gp)
                        guardPermEffects = guardPermEffects.append(geParsed.name)
                        gp = geParsed.nextPos
                        while isNewline(tokens, gp) { gp = gp + 1 }
                        if tokVal(tokens, gp) == "," { gp = gp + 1 }
                      }
                      _ => { gp = gp + 1 }
                    }
                  }
                  None => {}
                  _ => {}
                }
                while isNewline(tokens, gp) { gp = gp + 1 }
              }
              if tokVal(tokens, gp) == "}" { gp = gp + 1 }
            }
          } else {
            if gDepth == 1 and gv == "enforced_limits" {
              gp = gp + 1
              while isNewline(tokens, gp) { gp = gp + 1 }
              if tokVal(tokens, gp) == "{" {
                gp = gp + 1
                while gp < total and tokVal(tokens, gp) != "}" {
                  let glOpt = tokens.get(gp)
                  match glOpt {
                    Some(glTok) => {
                      match glTok.kind {
                        Identifier | Keyword => {
                          let glKey: String = glTok.value
                          gp = gp + 1
                          mut glVal: String = ""
                          if tokVal(tokens, gp) == ":" or tokVal(tokens, gp) == "=" {
                            gp = gp + 1
                            glVal = tokVal(tokens, gp)
                            gp = gp + 1
                          }
                          guardLimits = guardLimits.append(glKey + "=" + glVal)
                          while isNewline(tokens, gp) { gp = gp + 1 }
                          if tokVal(tokens, gp) == "," { gp = gp + 1 }
                        }
                        _ => { gp = gp + 1 }
                      }
                    }
                    None => {}
                    _ => {}
                  }
                  while isNewline(tokens, gp) { gp = gp + 1 }
                }
                if tokVal(tokens, gp) == "}" { gp = gp + 1 }
              }
            } else {
              if gDepth > 0 { gp = gp + 1 }
            }
          }
        }
      }
      if guardName != "" {
        guardDecls = guardDecls.append({ name: guardName, permittedEffects: guardPermEffects, enforcedLimits: guardLimits })
      }
      pos = gp
      consumed = true
    }

    // Version header (`@version N` on LINE 1): the language's own file header — parseProgram (.ts)
    // blanks line 1 the same way. Consumed silently ONLY when the `@` sits on line 1; a mid-file `@`
    // stays an unexpected token ("a mid-source header is not grammar" — the same rule as .ts).
    if consumed == false {
      if tv == "@" {
        mut atLine: Int = 0
        let atOpt = tokens.get(pos)
        match atOpt {
          Some(atTok) => { atLine = atTok.line }
          None => {}
          _ => {}
        }
        if atLine == 1 {
          while pos < total and isNewline(tokens, pos) == false { pos = pos + 1 }
          consumed = true
        }
      }
    }

    // Grammar-gap structural skip (DELIBERATE, silent): record/enum/type declarations are not yet in
    // this twin's grammar (Milestone-1+ scope; see #93). Consume the WHOLE declaration — a balanced
    // { } block, or to end-of-line when no brace opens (a one-line alias) — so known-but-unparsed
    // forms are CONSUMED, never flagged unexpected (R&D 0050: only UNCONSUMED non-trivia tokens are
    // errors). An unterminated block at EOF IS an error: FUNGI-PARSE-003 (missing close brace).
    // Remove each keyword from this skip as its parse milestone lands.
    if consumed == false {
      if tv == "record" or tv == "enum" or tv == "type" {
        mut sp: Int = pos + 1
        mut sDepth: Int = 0
        mut sawBrace: Bool = false
        mut sScan: Bool = true
        while sp < total and sScan {
          let sv: String = tokVal(tokens, sp)
          if sv == "{" {
            sDepth = sDepth + 1
            sawBrace = true
          }
          if sv == "}" {
            sDepth = sDepth - 1
            if sDepth == 0 { sScan = false }
          }
          if sawBrace == false and isNewline(tokens, sp) { sScan = false }
          sp = sp + 1
        }
        if sDepth > 0 {
          errs = errs.append("FUNGI-PARSE-003: unterminated '" + tv + "' declaration - missing '}' before end of input")
        }
        pos = sp
        consumed = true
      }
    }

    // Detect qualifier: pure | guarded | secure  (followed by "flow")
    // OR bare "flow" keyword.
    mut qualifier: String = ""
    mut namePos: Int = 0

    // Detect qualifier â€” no else-if; use sequential if blocks (Galerina: match on strings not yet supported for runtime values)
    if tv == "pure" or tv == "guarded" or tv == "secure" {
      if tokVal(tokens, pos + 1) == "flow" {
        qualifier = tv
        namePos = pos + 2
      }
      else {
        // FUNGI-PARSE-002 (mirrors parser.ts EXPECTED_FLOW_KEYWORD): a flow qualifier not followed
        // by `flow` is a dangling keyword — error + recover to end of line (anti-cascade).
        errs = errs.append("FUNGI-PARSE-002: expected 'flow' after '" + tv + "'")
        while pos < total and isNewline(tokens, pos) == false { pos = pos + 1 }
        consumed = true
      }
    }
    if tv == "flow" {
      qualifier = "flow"
      namePos = pos + 1
    }

    if qualifier == "" {
      // FUNGI-PARSE-001 (R&D 0050; mirrors parser.ts UNEXPECTED_TOKEN): an unconsumed, NON-TRIVIA
      // token at top level is a parse ERROR, never a silent skip — the fail-open this closes.
      // Trivia (newlines + comment tokens) advances silently, exactly as before. When `consumed`
      // is set, a recognized branch already advanced pos this iteration — nothing to do here
      // (advancing again would EAT the following token, the old off-by-one this also fixes).
      if consumed == false {
        if isTrivia(tokens, pos) {
          pos = pos + 1
        }
        else {
          errs = errs.append("FUNGI-PARSE-001: unexpected token '" + tv + "' at top level")
          // Anti-cascade (mirrors parser.ts:6177): one bad line = one error — consume to end of line.
          while pos < total and isNewline(tokens, pos) == false { pos = pos + 1 }
        }
      }
    }
    else {
      let flowName: String = tokVal(tokens, namePos)
      if flowName == "" {
        // FUNGI-PARSE-003: `flow` keyword with no name — a dangling declaration (EOF mid-header
        // or malformed source). Recorded fail-closed; pos advances past the keyword as before.
        errs = errs.append("FUNGI-PARSE-003: 'flow' keyword with no flow name (dangling declaration)")
        pos = namePos
      }
      else {
        mut p: Int = namePos + 1

        // Parse parameter list "(" ... ")"
        mut params: Array<FlowParam> = Array.empty()
        if tokVal(tokens, p) == "(" {
          p = p + 1
          params = parseParams(tokens, p)
          // Advance p past the params: scan for ")"
          mut skipP: Bool = true
          while skipP {
            let sv = tokVal(tokens, p)
            if sv == ")" { p = p + 1  skipP = false }
            if sv == "" { skipP = false }
            // only advance if neither stop condition was met
            let isStop: Bool = sv == ")" or sv == ""
            if isStop == false { p = p + 1 }
          }
        }

        // Return type: lexer emits "->" as a single Operator token.
        // Generic parameters like `Result<Int, String>` or `Option<String>` are
        // read as a single base name then a `< ... >` run â€” skip the generic run
        // so the cursor lands on `contract` / `{` correctly.
        mut returnType: String = ""
        if tokVal(tokens, p) == "->" {
          p = p + 1
          returnType = tokVal(tokens, p)
          p = p + 1
          // Skip generic type parameter < T, U > if present.
          if eTokVal(tokens, p) == "<" {
            p = p + 1
            mut genDepth: Int = 1
            while genDepth > 0 and p < total {
              let gv: String = eTokVal(tokens, p)
              if gv == "<" { genDepth = genDepth + 1 }
              if gv == ">" { genDepth = genDepth - 1 }
              p = p + 1
            }
          }
        }

        // Effects and domain guard: extract from contract block.
        // Task #56: also extract [conforms_to: X] attribute and effects { ... }
        // from inside the contract block rather than just skipping it entirely.
        mut efx: Array<String> = Array.empty()
        mut ctConformsTo: String = ""
        // finding (d): extract the governance metadata the parser previously hardcoded — the
        // classification (from the `value {}` sub-block) and the deterministic flag (from `safety {}`).
        // A flipped self-hosted parser that dropped these would silently skip the safety_critical
        // VAL-001/002 governance checks; extracting them is a parser-flip precondition (RD-0528).
        mut ctClassification: String = ""
        mut ctDeterministic: Bool = false
        mut captureClassNext: Bool = false

        // Skip newlines between the return type and the contract/body
        while isNewline(tokens, p) { p = p + 1 }

        // Parse the contract block: contract [conforms_to: X]? { ... }
        if tokVal(tokens, p) == "contract" {
          p = p + 1
          while isNewline(tokens, p) { p = p + 1 }

          // Optional [conforms_to: PolicyName] attribute
          if tokVal(tokens, p) == "[" {
            p = p + 1
            while isNewline(tokens, p) { p = p + 1 }
            if tokVal(tokens, p) == "conforms_to" {
              p = p + 1
              while isNewline(tokens, p) { p = p + 1 }
              if tokVal(tokens, p) == ":" {
                p = p + 1
                while isNewline(tokens, p) { p = p + 1 }
                let pnOpt = tokens.get(p)
                match pnOpt {
                  Some(pnTok) => {
                    // (c, sibling) 2026-07-23: VALUE-BASED — the conforms_to policy name is the token
                    // after `:` (positional; the block is bounded by `]`). The old `pnTok.kind ==
                    // "Identifier"` was the always-false TokenKind-vs-string compare (bridge 0086/0107)
                    // → ctConformsTo stayed unset → the `[conforms_to: X]` name silently dropped.
                    let pnv: String = pnTok.value
                    if pnv != "" and pnv != "]" { ctConformsTo = pnv }
                    p = p + 1
                  }
                  None => {}
                  _ => {}
                }
              }
            }
            // Consume tokens until ']'
            while p < total and tokVal(tokens, p) != "]" { p = p + 1 }
            if tokVal(tokens, p) == "]" { p = p + 1 }
            while isNewline(tokens, p) { p = p + 1 }
          }

          // Parse contract body: { ... }
          // Extract effects { e1, e2 } and skip everything else with brace counting
          if tokVal(tokens, p) == "{" {
            p = p + 1
            mut contractDepth: Int = 1
            while p < total and contractDepth > 0 {
              let cv = tokVal(tokens, p)
              if cv == "{" { contractDepth = contractDepth + 1 }
              if cv == "}" {
                contractDepth = contractDepth - 1
                if contractDepth == 0 {
                  p = p + 1
                }
              }
              // finding (d): keyword-scan for the governance metadata (these tokens are unique to
              // their sub-blocks). `classification <value>` — the value follows the keyword directly;
              // `require deterministic_execution` — a single distinct token. No p advance here (the
              // effects branch or the else below advances every token exactly once).
              if captureClassNext {
                if cv != "{" and cv != "}" { ctClassification = cv }
                captureClassNext = false
              }
              else {
                if cv == "classification" { captureClassNext = true }
              }
              if cv == "deterministic_execution" { ctDeterministic = true }
              // Extract effects { e1, e2 } at depth 1
              if contractDepth == 1 and cv == "effects" {
                p = p + 1
                while isNewline(tokens, p) { p = p + 1 }
                if tokVal(tokens, p) == "{" {
                  p = p + 1
                  // Collect dot-separated effect names until }
                  while p < total and tokVal(tokens, p) != "}" {
                    let etOpt = tokens.get(p)
                    match etOpt {
                      Some(etTok) => {
                        // Multi-variant match arms (task #62) â€” Identifier | Keyword share body
                        match etTok.kind {
                          Identifier | Keyword => {
                            let parsed = parseDotPath(tokens, p)
                            efx = efx.append(parsed.name)
                            p = parsed.nextPos
                            while isNewline(tokens, p) { p = p + 1 }
                            if tokVal(tokens, p) == "," { p = p + 1 }
                          }
                          _ => { p = p + 1 }
                        }
                      }
                      None => {}
                      _ => {}
                    }
                    while isNewline(tokens, p) { p = p + 1 }
                  }
                  if tokVal(tokens, p) == "}" { p = p + 1 }
                }
              } else {
                if contractDepth > 0 { p = p + 1 }
              }
            }
          }
        }

        // Skip newlines between the contract block and the body's opening brace.
        while isNewline(tokens, p) { p = p + 1 }

        // Parse body block â€” Milestone M-A: build the full structured Stmt/Expr
        // AST via parseBlock (folded from body-parser.fungi). parseBlock returns the
        // statement list AND the cursor position just past the closing "}".
        // Phase S6: also decompose the first top-level return into a ReturnExpr
        // (back-compat; type-checker.fungi + gir-emitter.fungi still consume it).
        mut bodyStmts: Array<Stmt> = Array.empty()
        mut returnExpr: ReturnExpr = { kind: "literal", litType: "Unknown", leftType: "", rightType: "" }
        if tokVal(tokens, p) == "{" {
          returnExpr = findReturnExpr(tokens, p + 1, total)
          let blk: BlockParse = parseBlock(tokens, p + 1)
          bodyStmts = blk.stmts
          p = blk.nextPos
        }
        else {
          // FUNGI-PARSE-004 (R&D 0050 class): a flow HEADER parsed but no `{` body block follows.
          // The flow record is still appended (shape-compatible with downstream stages); the error
          // is what makes it un-consumable — drivers refuse on non-empty errors, so a bodiless
          // flow can no longer be silently accepted.
          errs = errs.append("FUNGI-PARSE-004: flow '" + flowName + "' has no body block ('{' expected)")
        }

        flows = flows.append({
          kind: qualifier,
          name: flowName,
          params: params,
          returnType: returnType,
          effects: efx,
          conformsTo: ctConformsTo,
          body: bodyStmts,
          returnExpr: returnExpr,
          classification: ctClassification,
          deterministic: ctDeterministic,
          usedEffects: Array.empty()
        })
        pos = p
      }
    }
    }   // end else (not import)
  }

  return { flows: flows, errors: errs, imports: importPaths, policies: policies, guardDecls: guardDecls }
}
