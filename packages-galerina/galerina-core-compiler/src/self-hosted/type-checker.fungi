@version 1
/// @file: type-checker.fungi
/// @purpose: Stage B type checker — real subset, executing
/// @phase: 47
/// @version: 2.2
/// @status: functional subset — infers return-expression types and validates them; v2.2 adds static/bitfield/view/trap/step (R2 runs — #100 fixed)
///
/// Expected flow-record shape (from the Stage B ParseResult):
///   { name: String, returnType: String,
///     params: Array<{ name: String, typeName: String }>,
///     returnExpr: { kind: String, litType: String,
///                   leftType: String, rightType: String } }
///   returnExpr.kind is one of "literal" | "param" | "arith" | "compare".

// ============================================================
// Galerina Self-Hosted Type Checker — Phase 47
//
// Takes flow records from the Stage B ParseResult and performs real type
// checks, emitting TypeDiagnostic records with codes that match the Stage A
// compiler's canonical meanings:
//   FUNGI-TYPE-001  UnknownType            — return/param type not a known type
//   FUNGI-TYPE-008  InvalidReturnType      — return expr type ≠ declared return type (Stage-A canonical)
//   FUNGI-TYPE-004  InvalidBinaryOperation — arithmetic operand not Int
//
// Known types in the Stage B subset: Int, Bool, String, Array.
// ============================================================

record TypeDiagnostic {
  code: String
  message: String
  flowName: String
}

record TypeCheckResult {
  diagnostics: Array<Auto>
  flowCount: Int
  checkedAt: String
}

// ── Helpers ───────────────────────────────────────────────────

pure flow isKnownType(t: String) -> Bool
contract {
  intent { "True when t names a type the Stage B checker knows (Int/Bool/String/Array)." }
}
{
  if t == "Int" { return true }
  if t == "Bool" { return true }
  if t == "String" { return true }
  if t == "Array" { return true }
  return false
}

// True when t is an ISO 4217 active currency code that Money admits. The body between the
// <generated:currency-set> markers is emitted ONE-WAY by scripts/gen-unit-registry.mjs from the SAME pinned
// snapshot as MONEY_UNIT_TAGS (RD-0349 I1) and drift-gated (`--check`) — hand-edits are a finding. This is
// the in-language twin of the Stage-A currency validation, so the twin can reject Money<BANANAS>/GPB/XAU/XXX
// itself (FUNGI-TYPE-032) instead of mis-treating the tag as a type (the former FUNGI-TYPE-001 mis-emit).
