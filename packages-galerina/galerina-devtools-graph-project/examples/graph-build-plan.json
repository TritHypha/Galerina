{
  "root": ".",
  "policy": {
    "include": ["README.md", "docs/**", "packages/**", "packages-galerina/**"],
    "exclude": ["**/dist/**", "**/.build-dev/**", "**/.build-dev-*/*", "**/node_modules/**", "**/.env", "**/*.log"],
    "sources": ["markdown", "galerina-source", "typescript", "json-report", "schema"],
    "allowModelExtraction": false,
    "redactSecrets": true,
    "commitGeneratedGraph": false
  },
  "backendPolicy": {
    "preferred": ["Galerina_native", "graphify", "future_standard"],
    "allowGitBackends": false,
    "requirePinnedGitRef": true,
    "allowModelExtractionBackends": false
  },
  "backend": {
    "requested": "auto",
    "selected": "Galerina_native",
    "source": "built-in",
    "fallback": false,
    "reason": "Galerina native graph backend is available."
  },
  "output": {
    "jsonPath": "build/graph/galerina-devtools-project-graph.json",
    "htmlPath": "build/graph/galerina-devtools-project-graph.html",
    "reportPath": "build/graph/Galerina_GRAPH_REPORT.md",
    "aiMapPath": "build/graph/galerina-ai-map.md",
    "generatedFiles": [
      "build/graph/galerina-devtools-project-graph.json",
      "build/graph/galerina-devtools-project-graph.html",
      "build/graph/Galerina_GRAPH_REPORT.md",
      "build/graph/galerina-ai-map.md"
    ]
  }
}
