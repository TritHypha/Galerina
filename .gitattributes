# Auto detect text files and perform LF normalization
* text=auto

# Shell hooks must stay LF — a CRLF in the #!/bin/sh shebang breaks execution under sh.
scripts/hooks/* text eol=lf

# ── Regenerated graph / border / index artifacts (written LF by the graph tools). Pin eol=lf so Windows
#    autocrlf does not phantom-dirty them on every `graph` run (the recurring CRLF churn — 44 files flipping
#    line endings with no content change). They then diff cleanly and appear modified ONLY when the border/
#    index ACTUALLY changes, which keeps the tracked BOUNDARY.md useful for PR-diff review.
**/.graph/BOUNDARY.md   text eol=lf
build/graph/*.md        text eol=lf
build/kb-graph/*.md     text eol=lf
build/dev-tool-index/*  text eol=lf

# ── Benchmark result artifacts (written LF by the runner/snapshot scripts). Pin eol=lf so the committed
#    baseline (results/latest.json) + saved snapshots (results/archive/**) don't phantom-churn under Windows
#    autocrlf; a saved run then diffs cleanly and the NEXT benchmark's real change is visible against it.
packages-galerina/galerina-devtools-benchmarks/results/**   text eol=lf
