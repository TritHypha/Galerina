#!/bin/sh
# =============================================================================
# Galerina pre-commit hook — keep the generated //spore: dependency metadata current
# WITHOUT letting `galerina build` mutate your source.
#
# This is the "keep build pure + use a hook" alternative to `build --package`'s
# auto-refresh: the metadata lands at commit time (in *your* control), not as a
# silent side-effect of every build.
#
# Install (POSIX / macOS / Linux, or Git-Bash on Windows):
#     ln -sf ../../scripts/hooks/pre-commit .git/hooks/pre-commit
#   If symlinks are unavailable (plain Windows checkout):
#     cp scripts/hooks/pre-commit .git/hooks/pre-commit
#   then ensure it is executable:  chmod +x .git/hooks/pre-commit
#
# Set APP_DIR to your app's source root so the cross-file analysis (USES/USEDBY/
# IMPACT) is computed over the whole app — NOT the whole monorepo. Default ".".
# =============================================================================
set -e

APP_DIR="${GALERINA_APP_DIR:-.}"

# Fast exit: only do work when this commit actually touches .spore files.
staged_lln=$(git diff --cached --name-only --diff-filter=ACM -- '*.spore')
[ -z "$staged_lln" ] && exit 0

# Refresh the whole app's //spore: blocks in place (cross-file: a flow called from
# another file is never mislabelled "safe to delete"). Swap `node galerina.mjs`
# for `spore` once the CLI is globally linked (npm link).
node galerina.mjs deps --all "$APP_DIR" --write >/dev/null

# Re-stage any .spore the refresh changed, so the commit includes current metadata.
# (A dependency edit in one file can change another file's USEDBY — that file is
# re-staged too, which is correct: its metadata genuinely changed in this commit.)
changed=$(git diff --name-only -- '*.spore')
if [ -n "$changed" ]; then
  printf '%s\n' "$changed" | xargs git add
  echo "pre-commit: refreshed //spore: metadata on:"
  printf '  %s\n' $changed
fi

exit 0
