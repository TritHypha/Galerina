@version 1
/*
 * Validation utilities — imported by multi-file-import.fungi
 * Pure functions with no side effects — safe to import into any context.
 */

;; Checks that an email is well-formed (Stage A: non-empty); safe to import anywhere.
;; Pure — no runtime authority / no effects.
// @cause  [registerUser flow (multi-file-import.fungi)] -> called via the DAG-merged import.
// @effect [Verdict only] -> returns Bool; no state is mutated.
pure flow validateEmail(email: String) -> Bool
contract {
  intent "Check email format is valid"
  effects {}
}
{
  ;; Stage A: simple non-empty check
  ;; Stage B: full regex validation via stdlib
  trap email == "" : ERR_EMPTY_EMAIL
  return true
}

;; Checks an age falls within the acceptable range; safe to import anywhere.
;; Pure — no runtime authority / no effects.
;; Proof obligation: age >= 0 and age <= 150
// @cause  [registerUser flow (multi-file-import.fungi)] -> called via the DAG-merged import.
// @effect [Verdict only] -> returns Bool; no state is mutated.
pure flow validateAge(age: Int) -> Bool
contract {
  intent "Check age is within acceptable range"
  effects {}
  invariant {
    ensure age >= 0
    ensure age <= 150
  }
}
{
  trap age < 0 : ERR_NEGATIVE_AGE
  trap age > 150 : ERR_UNREALISTIC_AGE
  return true
}
