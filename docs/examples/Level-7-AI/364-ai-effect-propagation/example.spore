/// example: 364-ai-effect-propagation
/// test_status: stable
/// level: 7
/// concept: a pure flow calling an ai.inference flow inherits that effect and must declare it
/// expected_diagnostics: SPORE-EFFECT-002
/// ai_rule: Effects propagate upward; a caller that does not declare an effect used by its callee receives SPORE-EFFECT-002.

// classifyText is a guarded flow with effects [ai.inference]
// This pure caller does not declare ai.inference â€” illegal.
pure flow pureWrapper(text: String) -> Label
{
  // SPORE-EFFECT-002: ai.inference propagated from classifyText but not declared on pureWrapper
  let label = classifyText(text)
  return label
}
