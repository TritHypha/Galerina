{
  "name": "@galerina/cli",
  "version": "1.0.0-beta.2",
  "description": "Galerina compiler and runtime CLI — compile .fungi programs to WASM, run them, type-check with governance.",
  "type": "module",
  "bin": {
    "galerina": "./galerina.mjs",
    "fungi": "./galerina.mjs"
  },
  "scripts": {
    "test": "node scripts/run-all-tests.cjs",
    "test:core": "node scripts/run-all-tests.cjs --core",
    "test:list": "node scripts/run-all-tests.cjs --list",
    "brand-audit": "node scripts/brand-audit.mjs .",
    "audit:examples": "node scripts/audit-example-diagnostics.mjs",
    "audit:examples:selftest": "node scripts/audit-example-diagnostics.mjs --self-test",
    "audit:node-floor": "node scripts/audit-node-dependencies.mjs",
    "audit:imports": "node scripts/audit-import-governance.mjs",
    "audit:license": "node scripts/audit-license-compat.mjs",
    "audit:license:selftest": "node scripts/audit-license-compat.mjs --self-test"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["galerina", "compiler", "governance", "wasm"],
  "license": "Apache-2.0"
}
