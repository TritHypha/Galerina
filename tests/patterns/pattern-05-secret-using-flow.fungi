@version 1
// EXPECT: ACCEPT
// Pattern 5 — Secret-Using Flow (drcm_stable_v0)
// Reference: docs/patterns/applications/08-secrets.md
//
// Use when: a flow needs a credential — API key, signing key, database password.
// Rules: K-004 (SecureString sink guards), FUNGI-SECRET-001/002/003
//
// Deny-by-default egress secret-sink (H3): a SecureString — or ANY value derived from one —
// must never be transmitted to a network / egress sink. The checker cannot follow into a
// driver to prove it keeps the key safe, so it denies by default on EVERY receiver except the
// known on-host secret-handling primitives (crypto / vault / kms / signer / redactor ...).
// An email gateway sends off-host, so it is NOT one of them — a raw key handed to it is an
// exfiltration path the checker must assume the worst about.
//
// Correct model — governance / engine split (cf. pattern-10, "crypto-on-core"): the .fungi
// flow GOVERNS the credentialed send. It declares the capability grant
// `secrets { bind "EMAIL_API_KEY" }`, the `network.outbound` effect, and the audit obligation;
// the credential MATERIAL is provisioned and used by the trusted driver in the secrets/vault
// engine layer (galerina-ext-secrets-vault, govern-don't-absorb). The raw key is never threaded
// through the flow's egress call — which is why `send` below takes no key argument and still
// compiles clean.

type NotificationPayload = record { recipient: String, subject: String, body: String }
type NotifyError = enum { DeliveryFailed InvalidRecipient RateLimited }

secure flow sendPaymentNotification(readonly payload: NotificationPayload) -> Result<Void, NotifyError>
contract {
  intent { "Send a payment confirmation notification via the email gateway." }
  effects { network.outbound, audit.write }
  secrets { bind "EMAIL_API_KEY" }
  limits { request_time 3s }
  audit { require runtime report }
}
{
  // ✅ CORRECT — the flow governs the send; the gateway driver attaches the bound
  //    EMAIL_API_KEY credential in the engine layer. No raw SecureString crosses this
  //    egress boundary, so the deny-by-default secret-sink guard is satisfied.
  let result = EmailGateway.send(payload.recipient, payload.subject, payload.body)

  // ❌ Threading the raw credential — or anything derived from it — through the egress call
  //    is denied at compile time (the checker cannot verify the driver keeps it safe):
  //
  //      let apiKey: SecureString = Secrets.get("EMAIL_API_KEY")
  //      EmailGateway.send(payload.recipient, payload.subject, payload.body, apiKey)
  //          -> FUNGI-SECRET-002: SecureString transmitted to network sink 'EmailGateway.send'
  //      EmailGateway.send(payload.recipient, payload.subject, payload.body, Signer.hmac(apiKey, payload.recipient))
  //          -> FUNGI-SECRET-002 STILL fires: a value DERIVED from a secret is still a secret
  //      EmailGateway.send(payload.recipient, payload.subject, payload.body, redact(apiKey))
  //          -> compiles, but redact() DESTROYS the value (08-secrets.md: it does not lift the
  //             SecureString restriction) — a redacted key cannot authenticate. Not a real escape.
  //
  //    Other secret leaks the same guards catch:
  //      log.info("Key: " + apiKey)            -> FUNGI-SECRET-001: secret to log
  //      http.post(url, body: { key: apiKey }) -> FUNGI-SECRET-002: secret to network body
  //      return Ok({ debug_key: apiKey })      -> FUNGI-SECRET-003: secret in response

  AuditLog.write("PaymentNotificationSent")

  match result {
    Ok(_)  => return Ok(Void)
    Err(_) => return Err(NotifyError.DeliveryFailed)
    _      => return Err(NotifyError.DeliveryFailed)
  }
}
